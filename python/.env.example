# =============================================================================
# Cortex Capital — copy to `.env` and fill in (never commit real secrets)
#   cp .env.example .env
# =============================================================================

# --- LLMs (Groq primary, Anthropic fallback in code) ---
GROQ_API_KEY=gsk_replace_me
ANTHROPIC_API_KEY=sk-ant-replace_me

# --- Interactive Brokers (paper: TWS or IB Gateway on same machine) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=
# Set false until you explicitly want the swarm to send orders
IBKR_AUTO_TRADE=false

# --- OpenBB / data providers (set keys for the providers you enable) ---
# FRED (macro series inside OpenBB when using fred provider)
FRED_API_KEY=replace_me

# SEC / regulators (some OpenBB SEC routes may require identity headers)
# See https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=CortexCapital contact@yourdomain.com

# Financial Modeling Prep (optional; unlocks more fundamentals / transcripts)
FMP_API_KEY=replace_me

# Tiingo / Benzinga / etc. — add as you subscribe
TIINGO_TOKEN=
BENZINGA_API_KEY=

# US EIA (energy)
EIA_API_KEY=replace_me

# FIRMS / wildfire (NASA) — if you use a bridge that expects it
FIRMS_MAP_KEY=replace_me

# --- Crucix (local OSINT server; default port from Crucix repo) ---
CRUCIX_URL=http://127.0.0.1:3117

# --- Cortex memory (SQLite + optional sqlite-vec extension) ---
CORTEX_MEMORY_PATH=./data/cortex_memory.db

# --- Models (override defaults) ---
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
